# Linkist 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 服务器配置
NODE_ENV=development
PORT=3001

# 数据库配置
DB_TYPE=file  # file 或 postgres
DATABASE_URL=postgresql://linkist:YOUR_PASSWORD@localhost:5432/linkist

# JWT 配置 (生产环境必须设置!)
JWT_SECRET=your_secure_random_secret_at_least_32_chars_long

# 种子账户密码 (生产环境必须设置!)
SEED_PASSWORD=your_secure_seed_password

# PostgreSQL 配置 (docker-compose 使用)
POSTGRES_USER=linkist
POSTGRES_PASSWORD=your_secure_postgres_password

# CORS 配置
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP 配置 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# 基础 URL
BASE_URL=http://localhost:3001